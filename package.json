{
	"name": "@leninkhaidem/pi-crew",
	"version": "0.4.5",
	"description": "Sub-agent extension for the pi coding assistant",
	"license": "MIT",
	"repository": "github:leninkhaidem/pi-crew",
	"keywords": ["pi-package", "pi-extension", "subagent"],
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./events": "./src/types.ts"
	},
	"bin": {
		"pi-crew-tail": "./dist/cli/tail.js"
	},
	"files": ["src", "dist", "README.md", "LICENSE", "CHANGELOG.md"],
	"pi": {
		"extensions": ["./src/index.ts"]
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsc -p tsconfig.build.json && chmod +x dist/cli/tail.js",
		"prepack": "npm run build",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "PI_CREW_E2E=1 vitest run test/smoke"
	},
	"peerDependencies": {
		"@mariozechner/pi-agent-core": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@mariozechner/pi-agent-core": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"@types/node": "^20.14.0",
		"tsx": "^4.21.0",
		"typebox": "*",
		"typescript": "^5.5.0",
		"vitest": "^2.0.0"
	},
	"engines": {
		"node": ">=20"
	}
}
